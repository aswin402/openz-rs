# =============================================================================
# OpenZ Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control — it contains secrets!
#
# NOTE: .env is already in .gitignore. If git add --force is used, git will
# still include it. Use `git secret scan` or GitHub secret scanning to audit.
# =============================================================================

# ── LLM Provider API Keys ────────────────────────────────────────────────────
# At least ONE of these must be set for the agent to work.
# Keys set here override config.json values.

# OpenAI (also used for OpenAI-compatible providers)
# OPENAI_API_KEY="sk-..."

# Anthropic Claude
# ANTHROPIC_API_KEY="sk-ant-..."

# DeepSeek
# DEEPSEEK_API_KEY="sk-..."

# Groq (fast inference)
# GROQ_API_KEY="gsk_..."

# OpenRouter (multi-model router)
# OPENROUTER_API_KEY="sk-or-..."

# Mistral AI
# MISTRAL_API_KEY="..."

# Google AI Studio (Gemini models)
# GOOGLE_AI_STUDIO_API_KEY="AIza..."

# OpenCode Zen
# OPENCODE_ZEN_API_KEY="sk-..."
OPENCODE_ZEN_API_BASE="https://opencode.ai/zen/v1"

# Zhipu AI (Z.ai / GLM)
# Z_AI_API_KEY="..."

# NVIDIA NIM
# NVIDIA_API_KEY="nvapi-..."

# Cerebras (ultra-fast inference)
# CEREBRAS_API_KEY="csk-..."

# MiniMax
# MINIMAX_API_KEY="..."

# Ollama (local, no API key needed)
# OLLAMA_API_BASE="http://localhost:11434/v1"

# Cohere
# COHERE_API_KEY="..."

# LLM7 (token-based LLM proxy)
# LLM7_API_KEY="..."

# SambaNova
# SAMBANOVA_API_KEY="..."

# Hugging Face Inference API
# HUGGINGFACE_API_KEY="hf_..."

# ── Bot Channel Tokens ───────────────────────────────────────────────────────
# Uncomment and configure the channels you want to use.

# Telegram Bot Token (from @BotFather)
# TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# Discord Bot Token
# DISCORD_BOT_TOKEN="your-discord-bot-token"

# WhatsApp Business API credentials
# WHATSAPP_API_KEY="your-whatsapp-api-key"
# WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"

# Email credentials (IMAP + SMTP)
# EMAIL_IMAP_SERVER="imap.example.com"
# EMAIL_IMAP_PORT=993
# EMAIL_SMTP_SERVER="smtp.example.com"
# EMAIL_SMTP_PORT=465
# EMAIL_USERNAME="user@example.com"
# EMAIL_PASSWORD="your-email-password"

# ── OpenZ Runtime ────────────────────────────────────────────────────────────
# OPENZ_CONFIG_DIR="/path/to/custom/config"
# OPENZ_SILENT="true"  # Suppress MCP startup logs for background channels
